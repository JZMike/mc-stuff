# ── MikeCockpit ──────────────────────────────────────────────────────────────
APP_NAME=MikeCockpit
SERVER_NAME=MikeServer
# Porta dedicada do MikeCockpit (a 5700 estava ocupada pelo tailscale serve).
# Confirma livre no servidor:  ss -ltn | grep ':5599 '
PORT=5599

# Tailscale (para os links das apps)
TAILSCALE_HOST=mikeserver.tail228d40.ts.net

# ── Notificações push (Telegram) ─────────────────────────────────────────────
# 1) Fala com @BotFather no Telegram -> /newbot -> copia o token
# 2) Fala com @userinfobot -> copia o teu chat id (número)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Limiares de alerta (push quando ultrapassados de forma sustentada) ───────
ALERTS_ENABLED=true
ALERT_CPU_PCT=90
ALERT_MEM_PCT=90
ALERT_DISK_PCT=88
ALERT_TEMP_C=80
ALERT_EVAL_SECONDS=30
ALERT_COOLDOWN_SECONDS=900

# ── Ações no host ────────────────────────────────────────────────────────────
# true = permite reboot da VM e comandos da allowlist (precisa de privileged+pid:host)
ENABLE_HOST_CMD=true
